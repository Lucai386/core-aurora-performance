<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-users" author="luca.arnone">
        <createTable tableName="users" schemaName="aurora">
            <column name="id" type="SERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="keycloak_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="nome" type="VARCHAR(50)"/>
            <column name="cognome" type="VARCHAR(50)"/>
            <column name="codice_fiscale" type="CHAR(16)">
                <constraints unique="true"/>
            </column>
            <column name="codice_istat" type="CHAR(6)"/>
            <column name="ruolo" type="CHAR(2)"/>
            <column name="assegnazioni" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Check constraint per ruolo -->
        <sql>
            ALTER TABLE aurora.users 
            ADD CONSTRAINT users_ruolo_check 
            CHECK (ruolo IN ('AD', 'SC', 'DR', 'CS', 'CP', 'DB'));
        </sql>
    </changeSet>

</databaseChangeLog>
