<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-create-lpm" author="luca.arnone">
        <createTable tableName="lpm" schemaName="aurora">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codice_istat" type="CHAR(6)">
                <constraints nullable="false"/>
            </column>
            <column name="anno_inizio_mandato" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="anno_fine_mandato" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="titolo" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="descrizione" type="TEXT"/>
            <column name="stato" type="VARCHAR(20)" defaultValue="todo">
                <constraints nullable="false"/>
            </column>
            <column name="priorita" type="INTEGER" defaultValueNumeric="0"/>
            <column name="progresso" type="INTEGER" defaultValueNumeric="0"/>
            <column name="responsabile_id" type="INTEGER"/>
            <column name="dup_id" type="BIGINT"/>
            <column name="dup_titolo" type="VARCHAR(255)"/>
            <column name="created_by" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="INTEGER"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="INTEGER"/>
            <column name="deleted_reason" type="TEXT"/>
        </createTable>

        <!-- Foreign keys -->
        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm" 
            baseColumnNames="responsabile_id"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lpm_responsabile"/>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm" 
            baseColumnNames="created_by"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lpm_created_by"/>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm" 
            baseColumnNames="updated_by"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lpm_updated_by"/>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm" 
            baseColumnNames="deleted_by"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lpm_deleted_by"/>

        <!-- Check constraints -->
        <sql>
            ALTER TABLE aurora.lpm 
            ADD CONSTRAINT lpm_stato_check 
            CHECK (stato IN ('todo', 'in_progress', 'done', 'active', 'completed', 'suspended'));
        </sql>

        <sql>
            ALTER TABLE aurora.lpm 
            ADD CONSTRAINT lpm_progresso_check 
            CHECK (progresso >= 0 AND progresso &lt;= 100);
        </sql>
    </changeSet>

</databaseChangeLog>
