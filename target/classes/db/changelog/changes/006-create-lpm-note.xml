<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-create-lpm-note" author="luca.arnone">
        <createTable tableName="lpm_note" schemaName="aurora">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="lpm_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="testo" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="autore_id" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm_note" 
            baseColumnNames="lpm_id"
            referencedTableSchemaName="aurora"
            referencedTableName="lpm"
            referencedColumnNames="id"
            constraintName="fk_lpm_note_lpm"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="lpm_note" 
            baseColumnNames="autore_id"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_lpm_note_autore"/>
    </changeSet>

</databaseChangeLog>
