# Ambiente: PRODUZIONE
# Usato da: docker compose --env-file envs/prod.env up
# ATTENZIONE: non committare valori reali — usare secrets o variabili CI/CD
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://prod-db.aurora.example.com:5432/aurora_prod?currentSchema=aurora
DB_USERNAME=aurora_prod
DB_PASSWORD=${DB_PASSWORD_PROD}
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.aurora.example.com
KEYCLOAK_REALM=aurora-performance
SERVER_PORT=8081
