<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-add-struttura-id-to-attivita" author="copilot">
        <addColumn schemaName="aurora" tableName="attivita">
            <column name="struttura_id" type="integer">
                <constraints nullable="true"
                             foreignKeyName="fk_attivita_struttura"
                             references="aurora.strutture(id)"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
