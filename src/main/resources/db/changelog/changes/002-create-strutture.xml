<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-strutture" author="luca.arnone">
        <createTable tableName="strutture" schemaName="aurora">
            <column name="id" type="SERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="codice_istat" type="CHAR(6)"/>
            <column name="tipo" type="VARCHAR(50)"/>
            <column name="id_parent" type="INTEGER"/>
        </createTable>

        <addForeignKeyConstraint 
            baseTableSchemaName="aurora"
            baseTableName="strutture" 
            baseColumnNames="id_parent"
            referencedTableSchemaName="aurora"
            referencedTableName="strutture"
            referencedColumnNames="id"
            constraintName="fk_strutture_parent"/>
    </changeSet>

</databaseChangeLog>
