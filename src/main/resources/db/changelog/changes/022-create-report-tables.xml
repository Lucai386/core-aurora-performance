<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- 022 — Tabelle report_template e report per storicizzazione        -->
    <!--       documenti di performance (Legge Brunetta)                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <changeSet id="022-create-report-template" author="luca.arnone">
        <createTable tableName="report_template" schemaName="aurora">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codice" type="VARCHAR(80)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_report_template_codice"/>
            </column>
            <column name="nome" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="descrizione" type="TEXT"/>
            <column name="tipo" type="VARCHAR(60)">
                <constraints nullable="false"/>
            </column>
            <column name="template_html" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="struttura_campi" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="labels_i18n" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="versione" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="attivo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="022-create-report" author="luca.arnone">
        <createTable tableName="report" schemaName="aurora">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="codice_istat" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo" type="VARCHAR(60)">
                <constraints nullable="false"/>
            </column>
            <column name="titolo" type="VARCHAR(300)">
                <constraints nullable="false"/>
            </column>
            <column name="descrizione" type="TEXT"/>
            <column name="anno" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="trimestre" type="INT"/>
            <column name="stato" type="VARCHAR(20)" defaultValue="GENERATO">
                <constraints nullable="false"/>
            </column>
            <column name="utente_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="utente_nome" type="VARCHAR(200)"/>
            <column name="struttura_id" type="BIGINT"/>
            <column name="struttura_nome" type="VARCHAR(200)"/>
            <column name="template_id" type="BIGINT"/>
            <column name="dati_report" type="JSONB"/>
            <column name="parametri" type="JSONB"/>
            <column name="lingua" type="VARCHAR(5)" defaultValue="it"/>
            <column name="dimensione_bytes" type="BIGINT"/>
            <column name="generato_il" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="approvato_il" type="TIMESTAMP"/>
            <column name="approvato_da_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableSchemaName="aurora"
            baseTableName="report"
            baseColumnNames="utente_id"
            constraintName="fk_report_utente"
            referencedTableSchemaName="aurora"
            referencedTableName="users"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableSchemaName="aurora"
            baseTableName="report"
            baseColumnNames="template_id"
            constraintName="fk_report_template"
            referencedTableSchemaName="aurora"
            referencedTableName="report_template"
            referencedColumnNames="id"/>

        <createIndex tableName="report" schemaName="aurora" indexName="idx_report_codice_istat">
            <column name="codice_istat"/>
        </createIndex>
        <createIndex tableName="report" schemaName="aurora" indexName="idx_report_utente_id">
            <column name="utente_id"/>
        </createIndex>
        <createIndex tableName="report" schemaName="aurora" indexName="idx_report_tipo_anno">
            <column name="tipo"/>
            <column name="anno"/>
        </createIndex>
    </changeSet>

    <!-- Seed dei template di report -->
