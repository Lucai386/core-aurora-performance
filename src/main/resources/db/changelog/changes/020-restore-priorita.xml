<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- 
        Cleanup: rimuove colonna temporanea priorita_new se esiste.
        La colonna priorita è già VARCHAR(20) con valori BASSA, MEDIA, ALTA, CRITICA.
    -->
    
    <!-- Rimuovi colonna temporanea se presente -->
    <changeSet id="020-cleanup-priorita-new" author="luca.arnone">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="dup_progetti" schemaName="aurora" columnName="priorita_new"/>
        </preConditions>
        <dropColumn tableName="dup_progetti" schemaName="aurora" columnName="priorita_new"/>
    </changeSet>

</databaseChangeLog>
